---
import Layout from '../layouts/Layout.astro';
import { META } from '../config/content';
---

<Layout title={META.notFound.title} description={META.notFound.description}>
  <section class="bg-gradient-to-br from-pine to-jungle py-24 sm:py-32 min-h-[60vh] flex items-center">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-mint text-xs font-semibold tracking-[0.2em] uppercase mb-4">404</p>
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-white mb-6">Page not found</h1>
      <p class="text-fog/65 text-lg mb-10">
        The page you were looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center gap-2 bg-persimmon hover:bg-persimmon/90 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
        >
          Go home
        </a>
        <a
          href="/talks"
          class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
        >
          Browse talks
        </a>
      </div>
    </div>
  </section>
</Layout>
