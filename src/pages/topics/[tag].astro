---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import TalkCard from '../../components/TalkCard.astro';
import BlogCard from '../../components/BlogCard.astro';
import { readingTime } from '../../lib/reading-time';

export async function getStaticPaths() {
  const talks = await getCollection('talks');
  const writing = await getCollection('writing');
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  const tagSet = new Set<string>();
  for (const talk of talks) talk.data.tags.forEach(t => tagSet.add(t));
  for (const article of writing) article.data.tags.forEach(t => tagSet.add(t));
  for (const post of posts) post.data.tags.forEach(t => tagSet.add(t));

  return [...tagSet].map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;

const allTalks = await getCollection('talks');
const allWriting = await getCollection('writing');
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const filteredTalks = allTalks
  .filter(t => t.data.tags.includes(tag!))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const filteredPosts = allPosts
  .filter(p => p.data.tags.includes(tag!))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const filteredWriting = allWriting
  .filter(w => w.data.tags.includes(tag!))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout
  title={`Topic: ${tag}`}
  description={`All talks, blog posts, and writing tagged with "${tag}" by Jeroen van Erp.`}
>

  <!-- Header -->
  <section class="bg-gradient-to-br from-pine to-jungle py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <a
        href="/topics"
        class="inline-flex items-center gap-1.5 text-white/60 hover:text-white text-sm mb-8 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        All topics
      </a>
      <p class="text-white/70 text-xs font-semibold tracking-[0.2em] uppercase mb-3">Topic</p>
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-white mb-4">{tag}</h1>
      <p class="text-white/65">
        {filteredTalks.length + filteredPosts.length + filteredWriting.length} item{filteredTalks.length + filteredPosts.length + filteredWriting.length === 1 ? '' : 's'} tagged with this topic
      </p>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-20">

    <!-- Talks -->
    {filteredTalks.length > 0 && (
      <section>
        <div class="mb-8">
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-jungle dark:text-mint mb-1">Speaking</p>
          <h2 class="font-display text-2xl sm:text-3xl font-bold text-pine dark:text-fog">Talks</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {filteredTalks.map(talk => (
            <TalkCard
              title={talk.data.title}
              event={talk.data.event}
              date={talk.data.date}
              endDate={talk.data.endDate}
              type={talk.data.type}
              tags={talk.data.tags}
              slug={talk.id}
              slides_url={talk.data.slides_url}
              video_url={talk.data.video_url}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Blog Posts -->
    {filteredPosts.length > 0 && (
      <section>
        <div class="mb-8">
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-jungle dark:text-mint mb-1">On this site</p>
          <h2 class="font-display text-2xl sm:text-3xl font-bold text-pine dark:text-fog">Blog Posts</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {filteredPosts.map(post => (
            <BlogCard
              title={post.data.title}
              date={post.data.date}
              description={post.data.description}
              tags={post.data.tags}
              slug={post.id}
              readingTime={readingTime(post.body)}
            />
          ))}
        </div>
      </section>
    )}

    <!-- External Writing -->
    {filteredWriting.length > 0 && (
      <section>
        <div class="mb-8">
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-jungle dark:text-mint mb-1">External</p>
          <h2 class="font-display text-2xl sm:text-3xl font-bold text-pine dark:text-fog">External Writing</h2>
        </div>
        <div class="space-y-4">
          {filteredWriting.map(article => (
            <article class="group flex flex-col sm:flex-row sm:items-start gap-4 bg-white dark:bg-white/8 border border-pine/10 dark:border-white/10 rounded-xl p-5 hover:border-jungle/50 dark:hover:border-mint/30 hover:shadow-lg transition-all duration-200 hover:-translate-y-0.5">
              <div class="flex-shrink-0 sm:w-44">
                <time datetime={article.data.date.toISOString()} class="text-xs text-pine/70 dark:text-fog/70 block mb-1">
                  {article.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                </time>
                <span class="inline-flex text-xs font-semibold text-jungle dark:text-mint">
                  {article.data.publication}
                </span>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="font-display font-semibold leading-snug mb-2">
                  <a
                    href={article.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-pine dark:text-fog group-hover:text-jungle dark:group-hover:text-mint transition-colors"
                  >
                    {article.data.title}
                  </a>
                </h3>
                <p class="text-sm text-pine/70 dark:text-fog/70 leading-relaxed mb-3">
                  {article.data.description}
                </p>
                <div class="flex flex-wrap gap-1.5">
                  {article.data.tags.slice(0, 4).map(t => (
                    <a
                      href={`/topics/${encodeURIComponent(t)}`}
                      class="text-xs bg-mint/15 dark:bg-pine/60 text-pine/70 dark:text-mint/80 px-2 py-0.5 rounded-full border border-mint/20 dark:border-mint/15 hover:bg-mint/30 dark:hover:bg-pine/80 transition-colors"
                    >
                      {t}
                    </a>
                  ))}
                </div>
              </div>
              <a
                href={article.data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex-shrink-0 self-center hidden sm:block"
                aria-label={`Open ${article.data.title} (external)`}
              >
                <svg class="w-4 h-4 text-pine/30 dark:text-fog/30 group-hover:text-jungle dark:group-hover:text-mint transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </article>
          ))}
        </div>
      </section>
    )}

    {filteredTalks.length === 0 && filteredPosts.length === 0 && filteredWriting.length === 0 && (
      <div class="rounded-xl border-2 border-dashed border-pine/10 dark:border-mint/10 p-12 text-center">
        <p class="text-pine/40 dark:text-fog/40 text-sm">No content found for this topic.</p>
      </div>
    )}

  </div>

</Layout>
