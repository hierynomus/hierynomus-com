---
import Layout from '../layouts/Layout.astro';
import { SITE, TOPICS } from '../config/site';
import { META, BIO, CTA, SECTIONS } from '../config/content';
import SpeakingCtaSection from '../components/SpeakingCtaSection.astro';
---

<Layout
  title="About"
  description={META.about.description}
>

  <!-- Header -->
  <section class="bg-gradient-to-br from-pine to-jungle py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-white/70 text-xs font-semibold tracking-[0.2em] uppercase mb-3">About</p>
      <h1 class="font-display text-4xl sm:text-5xl font-bold text-white mb-4">Jeroen van Erp</h1>
      <p class="text-white/65 text-lg max-w-2xl">
        {BIO.tagline}
      </p>
    </div>
  </section>

  <!-- Bio + Headshot -->
  <section class="py-16 sm:py-20 bg-white dark:bg-pine">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Text -->
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-jungle dark:text-mint mb-2">Who I Am</p>
          <h2 class="font-display text-3xl font-bold text-pine dark:text-fog mb-6">
            {BIO.sectionHeading}
          </h2>
          <div class="space-y-4 text-pine/75 dark:text-fog/75 leading-relaxed">
            {BIO.full.map(para => <p>{para}</p>)}
          </div>

          <!-- Location + languages -->
          <div class="flex flex-wrap items-center gap-4 mt-8 text-sm text-pine/60 dark:text-fog/60">
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4 flex-shrink-0 text-jungle dark:text-mint" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              {SITE.location}
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4 flex-shrink-0 text-jungle dark:text-mint" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802" />
              </svg>
              Speaks: {SITE.languages.join(' & ')}
            </span>
          </div>
        </div>

        <!-- Headshot + SUSE badge -->
        <div class="flex justify-center lg:justify-end">
          <div class="relative">
            <div class="w-56 h-56 sm:w-72 sm:h-72 lg:w-80 lg:h-80 rounded-2xl overflow-hidden border border-pine/15 dark:border-mint/15 shadow-xl">
              <img
                src="/jeroen-van-erp.jpg"
                alt="Jeroen van Erp"
                class="w-full h-full object-cover"
                width="320"
                height="320"
              />
            </div>
            <!-- SUSE badge -->
            <div class="absolute -bottom-3 -right-3 bg-persimmon text-white text-xs font-bold px-3 py-1.5 rounded-lg shadow-lg">
              @ SUSE
            </div>
            <!-- Decorative ring -->
            <div class="absolute -inset-3 rounded-2xl border border-pine/10 dark:border-mint/10 pointer-events-none"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Topics I cover -->
  <section class="py-16 bg-fog/50 dark:bg-white/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-jungle dark:text-mint mb-2">{SECTIONS.topics.eyebrow}</p>
      <h2 class="font-display text-3xl font-bold text-pine dark:text-fog mb-8">{SECTIONS.topics.heading}</h2>
      <div class="flex flex-wrap gap-3">
        {TOPICS.map(topic => (
          <span class="bg-white dark:bg-pine border border-jungle/20 dark:border-mint/20 text-pine/80 dark:text-fog/80 text-sm px-4 py-2 rounded-full font-medium hover:border-jungle/50 dark:hover:border-mint/40 transition-colors">
            {topic}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Currently at SUSE -->
  <section class="py-16 bg-white dark:bg-pine">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-jungle dark:text-mint mb-2">{SECTIONS.currentRole.eyebrow}</p>
      <h2 class="font-display text-3xl font-bold text-pine dark:text-fog mb-8">{SECTIONS.currentRole.heading}</h2>
      <div class="inline-flex items-center gap-4 bg-fog/60 dark:bg-white/8 border border-pine/10 dark:border-mint/10 rounded-xl px-6 py-4">
        <div class="w-10 h-10 rounded-lg bg-jungle flex items-center justify-center flex-shrink-0">
          <span class="text-white text-sm font-bold">S</span>
        </div>
        <div>
          <p class="font-semibold text-pine dark:text-fog">SUSE</p>
          <p class="text-pine/55 dark:text-fog/55 text-sm">The world's largest independent open source company</p>
        </div>
      </div>
      <p class="mt-6 text-pine/70 dark:text-fog/70 leading-relaxed max-w-2xl">
        {BIO.suseRole}
      </p>
    </div>
  </section>

  <SpeakingCtaSection heading={CTA.section.heading} subtext={CTA.section.subtext} />

</Layout>
