---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import TalkCard from '../components/TalkCard.astro';
import { SOCIAL, SITE, TOPICS } from '../config/site';
import { META, BIO, CTA, HERO, SECTIONS } from '../config/content';
import ProjectCard from '../components/ProjectCard.astro';

const allTalks = await getCollection('talks');
const sortedTalks = allTalks.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const featuredTalks = sortedTalks.filter(t => t.data.featured).slice(0, 3);
const recentTalks = featuredTalks.length >= 3 ? featuredTalks : sortedTalks.slice(0, 3);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const allWriting = await getCollection('writing');

type WritingItem = {
  title: string;
  date: Date;
  description: string;
  tags: string[];
  href: string;
  external: boolean;
  publication?: string;
};

const featuredPosts = allPosts.filter(p => p.data.featured);
const featuredWriting = allWriting.filter(w => w.data.featured);

// Fall back to most-recent if nothing is flagged
const blogSource = featuredPosts.length > 0 ? featuredPosts : allPosts;
const writingSource = featuredWriting.length > 0 ? featuredWriting : allWriting;

const recentWriting: WritingItem[] = [
  ...blogSource.map(p => ({
    title: p.data.title,
    date: p.data.date,
    description: p.data.description,
    tags: p.data.tags,
    href: `/blog/${p.id}`,
    external: false,
  })),
  ...writingSource.map(w => ({
    title: w.data.title,
    date: w.data.date,
    description: w.data.description,
    tags: w.data.tags,
    href: w.data.url,
    external: true,
    publication: w.data.publication,
  })),
].sort((a, b) => b.date.getTime() - a.date.getTime()).slice(0, 5);

const allProjects = await getCollection('projects');
const featuredProjects = allProjects.filter(p => p.data.featured);
const displayProjects = featuredProjects.length > 0 ? featuredProjects : allProjects;

const totalTalks = allTalks.length;
const keynotes = allTalks.filter(t => t.data.type === 'keynote').length;
const uniqueEvents = new Set(allTalks.map(t => t.data.event)).size;

---

<Layout title={META.home.title} description={META.home.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Jeroen van Erp",
      "url": SITE.url,
      "email": SITE.email,
      "jobTitle": "Technology Advocate",
      "description": SITE.description,
      "image": `${SITE.url}/jeroen-van-erp.jpg`,
      "sameAs": [
        SOCIAL.github,
        SOCIAL.linkedin,
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "SUSE",
        "url": "https://suse.com",
      },
      "knowsLanguage": SITE.languages.map(lang => ({
        "@type": "Language",
        "name": lang,
      })),
      "nationality": {
        "@type": "Country",
        "name": "Netherlands",
      },
    })} />
  </Fragment>

  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-gradient-to-br from-pine to-jungle">

    <!-- Stage light glow -->
    <div
      class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[700px] h-72 rounded-full blur-3xl"
      style="background: radial-gradient(ellipse, rgba(48,186,120,0.22) 0%, transparent 70%);"
    ></div>

    <!-- Subtle dot grid -->
    <div
      class="absolute inset-0 opacity-[0.04]"
      style="background-image: radial-gradient(circle, #90ebcd 1px, transparent 1px); background-size: 32px 32px;"
    ></div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <!-- Text -->
        <div class="order-2 lg:order-1">
          <p class="text-white/85 text-xs font-semibold tracking-[0.2em] uppercase mb-5">
            {HERO.eyebrow}
          </p>
          <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-[1.05] mb-6">
            Jeroen<br/>van Erp
          </h1>
          <p class="text-fog/70 text-lg leading-relaxed mb-6 max-w-lg">
            {HERO.tagline}
            {' '}{HERO.currentRole} <span class="text-white font-semibold">SUSE</span>.
          </p>

          <!-- Location + languages -->
          <div class="flex flex-wrap items-center gap-4 mb-10 text-sm text-white/80">
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              {SITE.location}
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802" />
              </svg>
              {SITE.languages.join(' · ')}
            </span>
          </div>

          <!-- Stats -->
          <div class="flex gap-10 mb-10">
            <div>
              <p class="font-display text-4xl font-bold text-white">{totalTalks}</p>
              <p class="text-white/70 text-sm mt-0.5">Talks</p>
            </div>
            <div class="w-px bg-white/15"></div>
            <div>
              <p class="font-display text-4xl font-bold text-white">{uniqueEvents}</p>
              <p class="text-white/70 text-sm mt-0.5">Events</p>
            </div>
            <div class="w-px bg-white/15"></div>
            <div>
              <p class="font-display text-4xl font-bold text-white">{keynotes}</p>
              <p class="text-white/70 text-sm mt-0.5">Keynotes</p>
            </div>
          </div>

          <!-- CTAs -->
          <div class="flex flex-wrap gap-4">
            <a
              href="/talks"
              class="inline-flex items-center gap-2 bg-jungle hover:bg-jungle/90 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
            >
              See My Talks
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a
              href="#contact"
              class="inline-flex items-center gap-2 bg-persimmon hover:bg-persimmon/90 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
            >
              Get in Touch
            </a>
          </div>
        </div>

        <!-- Headshot -->
        <div class="order-1 lg:order-2 flex justify-center lg:justify-end">
          <div class="relative">
            <div class="w-56 h-56 sm:w-72 sm:h-72 lg:w-80 lg:h-80 rounded-2xl overflow-hidden border border-mint/25 shadow-2xl shadow-black/50">
              <img
                src="/jeroen-van-erp.jpg"
                alt="Jeroen van Erp"
                class="w-full h-full object-cover"
                width="320"
                height="320"
              />
            </div>
            <!-- SUSE badge -->
            <div class="absolute -bottom-3 -right-3 bg-persimmon text-white text-xs font-bold px-3 py-1.5 rounded-lg shadow-lg">
              @ SUSE
            </div>
            <!-- Decorative ring -->
            <div class="absolute -inset-3 rounded-2xl border border-mint/10 pointer-events-none"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── RECENT TALKS ─────────────────────────────────────────────────── -->
  <section class="py-20 bg-white dark:bg-pine">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-jungle dark:text-mint mb-2">Speaking</p>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-pine dark:text-fog">Recent Talks</h2>
        </div>
        <a
          href="/talks"
          class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-jungle dark:text-mint hover:underline underline-offset-2"
        >
          All talks →
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentTalks.map(talk => (
          <TalkCard
            title={talk.data.title}
            event={talk.data.event}
            date={talk.data.date}
            endDate={talk.data.endDate}
            type={talk.data.type}
            tags={talk.data.tags}
            slug={talk.id}
            slides_url={talk.data.slides_url}
            video_url={talk.data.video_url}
          />
        ))}
      </div>

      <div class="mt-8 sm:hidden text-center">
        <a href="/talks" class="text-sm font-medium text-jungle dark:text-mint hover:underline underline-offset-2">
          View all {totalTalks} talks →
        </a>
      </div>
    </div>
  </section>

  <!-- ─── ABOUT ─────────────────────────────────────────────────────────── -->
  <section id="about" class="py-20 bg-fog/50 dark:bg-white/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-jungle dark:text-mint mb-2">{SECTIONS.about.eyebrow}</p>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-pine dark:text-fog mb-6">
            {SECTIONS.about.heading}
          </h2>
          <div class="space-y-4 text-pine/75 dark:text-fog/75 leading-relaxed">
            {BIO.short.map(para => <p>{para}</p>)}
            <p>
              <a href="/about" class="font-medium text-jungle dark:text-mint hover:underline underline-offset-2">
                More about me →
              </a>
            </p>
          </div>
        </div>

        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-jungle dark:text-mint mb-4">Topics I cover</p>
          <div class="flex flex-wrap gap-2 mb-10">
            {TOPICS.map(topic => (
              <span class="bg-white dark:bg-pine border border-jungle/20 dark:border-mint/20 text-pine/80 dark:text-fog/80 text-sm px-3 py-1.5 rounded-full">
                {topic}
              </span>
            ))}
          </div>

          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-jungle dark:text-mint mb-4">Currently at</p>
          <div class="inline-flex items-center gap-3 bg-white dark:bg-pine border border-pine/10 dark:border-mint/10 rounded-xl px-5 py-3">
            <!-- SUSE green square logo placeholder -->
            <div class="w-8 h-8 rounded bg-jungle flex items-center justify-center flex-shrink-0">
              <span class="text-white text-xs font-bold">S</span>
            </div>
            <div>
              <p class="font-semibold text-pine dark:text-fog text-sm">SUSE</p>
              <p class="text-pine/50 dark:text-fog/50 text-xs">The world's largest independent open source company</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── OPEN SOURCE ───────────────────────────────────────────────────── -->
  <section id="projects" class="py-20 bg-white dark:bg-pine">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-jungle dark:text-mint mb-2">Open Source</p>
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-pine dark:text-fog mb-10">
        Notable Projects
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        {displayProjects.map(project => (
          <ProjectCard
            name={project.data.name}
            description={project.data.description}
            url={project.data.url}
            language={project.data.language}
            license={project.data.license}
            stars={project.data.stars}
            forks={project.data.forks}
          />
        ))}
      </div>

      <a
        href={SOCIAL.github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-medium text-jungle dark:text-mint hover:underline underline-offset-2"
      >
        View all repositories on GitHub →
      </a>
    </div>
  </section>

  <!-- ─── WRITING ────────────────────────────────────────────────────────────── -->
  <!-- Hidden when there are no published posts and no external writing yet — auto-reveals once content exists -->
  {recentWriting.length > 0 && (
  <section id="writing" class="py-20 bg-fog/50 dark:bg-white/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-jungle dark:text-mint mb-2">Writing</p>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-pine dark:text-fog">Latest Writing</h2>
        </div>
        <a
          href="/writing"
          class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-jungle dark:text-mint hover:underline underline-offset-2"
        >
          All writing →
        </a>
      </div>

      <div class="space-y-3">
        {recentWriting.map(item => (
          <a
            href={item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
            class="group flex flex-col sm:flex-row sm:items-start gap-4 bg-white dark:bg-white/8 border border-pine/10 dark:border-white/10 rounded-xl p-5 hover:border-jungle/50 dark:hover:border-mint/30 hover:shadow-lg transition-all duration-200 hover:-translate-y-0.5"
          >
            <!-- Badge column -->
            <div class="flex-shrink-0 sm:w-36 flex sm:flex-col items-center sm:items-start gap-2 sm:gap-1.5 pt-0.5">
              <!-- Type pill -->
              {item.external ? (
                <span class="inline-flex items-center text-xs font-semibold px-2.5 py-1 rounded-full bg-waterhole text-white whitespace-nowrap">
                  Article
                </span>
              ) : (
                <span class="inline-flex items-center text-xs font-semibold px-2.5 py-1 rounded-full bg-persimmon text-white whitespace-nowrap">
                  Blog
                </span>
              )}
              <!-- Publication name (external only) -->
              {item.external && item.publication && (
                <span class="text-xs text-pine/70 dark:text-fog/60 leading-tight">{item.publication}</span>
              )}
              <!-- Date -->
              <time datetime={item.date.toISOString()} class="text-xs text-pine/60 dark:text-fog/55 whitespace-nowrap">
                {item.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
              </time>
            </div>

            <!-- Content -->
            <div class="flex-1 min-w-0">
              <h3 class="font-display font-semibold text-pine dark:text-fog group-hover:text-jungle dark:group-hover:text-mint transition-colors leading-snug mb-2">
                {item.title}
              </h3>
              <p class="text-sm text-pine/60 dark:text-fog/55 leading-relaxed mb-3">
                {item.description}
              </p>
              <div class="flex flex-wrap gap-1.5">
                {item.tags.slice(0, 4).map(tag => (
                  <span class="text-xs bg-mint/15 dark:bg-pine/60 text-pine/70 dark:text-mint/80 px-2 py-0.5 rounded-full border border-mint/20 dark:border-mint/15">
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            <!-- Arrow icon -->
            {item.external ? (
              <svg class="flex-shrink-0 w-4 h-4 text-pine/30 dark:text-fog/30 group-hover:text-jungle dark:group-hover:text-mint transition-colors self-center hidden sm:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            ) : (
              <svg class="flex-shrink-0 w-4 h-4 text-pine/30 dark:text-fog/30 group-hover:text-jungle dark:group-hover:text-mint transition-colors self-center hidden sm:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            )}
          </a>
        ))}
      </div>

      <div class="mt-8 text-center sm:hidden">
        <a href="/writing" class="text-sm font-medium text-jungle dark:text-mint hover:underline underline-offset-2">
          All writing →
        </a>
      </div>
    </div>
  </section>
  )}

  <!-- ─── BOOK ME / CONTACT ─────────────────────────────────────────────── -->
  <section id="contact" class="relative overflow-hidden bg-gradient-to-br from-pine to-jungle py-24">

    <!-- Stage light glow -->
    <div
      class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[500px] h-48 rounded-full blur-3xl pointer-events-none"
      style="background: radial-gradient(ellipse, rgba(48,186,120,0.18) 0%, transparent 70%);"
    ></div>

    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-white/85 text-xs font-semibold tracking-[0.2em] uppercase mb-4">Speaking Enquiries</p>
      <h2 class="font-display text-3xl sm:text-5xl font-bold text-white mb-6">
        Want a compelling talk<br/>at your event?
      </h2>
      <p class="text-fog/65 text-lg leading-relaxed mb-6 max-w-xl mx-auto">
        I speak on Kubernetes, cloud-native security, containers, and open source.
        Cloud Native Foundation events, CNCF-adjacent meetups, and tech conferences —
        get in touch and let's make it happen.
      </p>

      <!-- Location + languages -->
      <div class="flex flex-wrap items-center justify-center gap-4 mb-10 text-sm text-white/75">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
          {SITE.location}
        </span>
        <span class="w-px h-4 bg-white/20"></span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802" />
          </svg>
          {SITE.languages.join(' · ')}
        </span>
      </div>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href={`mailto:${SITE.email}`}
          class="inline-flex items-center gap-2 bg-persimmon hover:bg-persimmon/90 text-white font-semibold px-8 py-3.5 rounded-lg transition-colors"
        >
          Get in Touch
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a
          href={SOCIAL.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-mint/60 text-fog hover:border-mint hover:text-mint font-semibold px-8 py-3.5 rounded-lg transition-colors"
        >
          LinkedIn ↗
        </a>
      </div>
    </div>
  </section>

</Layout>
