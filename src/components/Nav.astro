---
import ThemeToggle from './ThemeToggle.astro';
import { SOCIAL } from '../config/site';

const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/talks', label: 'Talks' },
  { href: '/writing', label: 'Writing' },
  { href: '/#projects', label: 'Projects' },
  { href: '/#contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 backdrop-blur-md bg-white/85 dark:bg-pine/85 border-b border-pine/10 dark:border-mint/10"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a
        href="/"
        class="font-display font-bold text-lg text-pine dark:text-fog hover:text-jungle dark:hover:text-mint transition-colors"
      >
        Jeroen van Erp
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-6">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors',
              currentPath.startsWith(link.href) && link.href !== '/'
                ? 'text-jungle dark:text-mint'
                : 'text-pine/65 dark:text-fog/65 hover:text-pine dark:hover:text-fog',
            ]}
          >
            {link.label}
          </a>
        ))}

        <!-- Social icons -->
        <div class="flex items-center gap-1">
          <a
            href={SOCIAL.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="p-1.5 rounded-lg text-pine/50 dark:text-fog/50 hover:text-pine dark:hover:text-fog hover:bg-pine/5 dark:hover:bg-mint/10 transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
          <a
            href={SOCIAL.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="p-1.5 rounded-lg text-pine/50 dark:text-fog/50 hover:text-pine dark:hover:text-fog hover:bg-pine/5 dark:hover:bg-mint/10 transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>

        <ThemeToggle />
        <a
          href="/#contact"
          class="bg-persimmon hover:bg-persimmon/90 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors"
        >
          Get in Touch
        </a>
      </nav>

      <!-- Mobile controls -->
      <div class="flex md:hidden items-center gap-2">
        <ThemeToggle />
        <button
          id="mobile-menu-btn"
          class="p-2 rounded-lg text-pine/70 dark:text-fog/70 hover:bg-pine/5 dark:hover:bg-mint/10 transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" d="M3 12h18M3 6h18M3 18h18" />
            <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden border-t border-pine/10 dark:border-mint/10 py-4 space-y-1"
    >
      {navLinks.map(link => (
        <a
          href={link.href}
          class="block px-2 py-2 text-sm font-medium text-pine/70 dark:text-fog/70 hover:text-jungle dark:hover:text-mint rounded-lg hover:bg-pine/5 dark:hover:bg-mint/10 transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/#contact"
        class="block mt-3 bg-persimmon hover:bg-persimmon/90 text-white text-sm font-semibold px-4 py-2.5 rounded-lg text-center transition-colors"
      >
        Get in Touch
      </a>

      <!-- Mobile social icons -->
      <div class="flex items-center gap-1 pt-2 border-t border-pine/10 dark:border-mint/10 mt-2">
        <a
          href={SOCIAL.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="p-2 rounded-lg text-pine/60 dark:text-fog/60 hover:text-pine dark:hover:text-fog hover:bg-pine/5 dark:hover:bg-mint/10 transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </a>
        <a
          href={SOCIAL.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="p-2 rounded-lg text-pine/60 dark:text-fog/60 hover:text-pine dark:hover:text-fog hover:bg-pine/5 dark:hover:bg-mint/10 transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const close = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    hamburger?.classList.toggle('hidden', !isOpen ? false : false);
    close?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
