---
import { CTA } from '../config/content';

interface Props {
  heading?: string;
  subtext?: string;
}

const {
  heading = CTA.section.heading,
  subtext = CTA.section.subtext,
} = Astro.props;
---

<section class="py-16 bg-fog/50 dark:bg-white/5">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-display text-3xl font-bold text-pine dark:text-fog mb-4">
      {heading}
    </h2>
    <p class="text-pine/65 dark:text-fog/65 text-lg mb-8 max-w-xl mx-auto">
      {subtext}
    </p>
    <a
      href="/#contact"
      class="inline-flex items-center gap-2 bg-persimmon hover:bg-persimmon/90 text-white font-semibold px-8 py-3.5 rounded-lg transition-colors"
    >
      Get in Touch
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </div>
</section>
