---
interface Props {
  name: string;
  description: string;
  url: string;
  language: string;
  license: string;
  stars: number;
  forks: number;
}

const { name, description, url, language, license, stars, forks } = Astro.props;

function fmt(n: number): string {
  if (n >= 10000) return `${Math.round(n / 1000)}k`;
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`;
  return String(n);
}

// GitHub language colour palette (subset)
const LANG_COLORS: Record<string, string> = {
  Java: '#b07219',
  Kotlin: '#A97BFF',
  TypeScript: '#3178c6',
  JavaScript: '#f1e05a',
  Python: '#3572A5',
  Go: '#00ADD8',
  Rust: '#dea584',
  Ruby: '#701516',
  Swift: '#F05138',
  'C#': '#178600',
  'C++': '#f34b7d',
  Groovy: '#e69f56',
  Shell: '#89e051',
};
const langColor = LANG_COLORS[language] ?? '#8b949e';
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group flex flex-col bg-white dark:bg-white/8 border border-pine/10 dark:border-white/10 rounded-xl p-6 hover:border-jungle/50 dark:hover:border-mint/30 hover:shadow-lg transition-all duration-200 hover:-translate-y-0.5"
>
  <!-- Header row -->
  <div class="flex items-start justify-between mb-4">
    <div class="flex items-center gap-3 min-w-0">
      <div class="w-9 h-9 rounded-lg bg-pine/5 dark:bg-mint/10 flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-pine/50 dark:text-mint/60" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </div>
      <h3 class="font-display font-bold text-xl text-pine dark:text-fog group-hover:text-jungle dark:group-hover:text-mint transition-colors truncate">
        {name}
      </h3>
    </div>
    <svg class="w-4 h-4 text-pine/30 dark:text-fog/30 group-hover:text-jungle dark:group-hover:text-mint transition-colors flex-shrink-0 mt-1 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </div>

  <!-- Description -->
  <p class="text-pine/65 dark:text-fog/65 text-sm leading-relaxed mb-5 flex-1">
    {description}
  </p>

  <!-- Footer: language · stars · forks · license -->
  <div class="flex items-center gap-3 text-xs text-pine/50 dark:text-fog/50 flex-wrap">
    <span class="flex items-center gap-1.5">
      <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style={`background-color: ${langColor}`}></span>
      {language}
    </span>

    <span class="text-pine/20 dark:text-fog/20">·</span>

    <span class="flex items-center gap-1">
      <!-- Star icon -->
      <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
      </svg>
      {fmt(stars)}
    </span>

    <span class="flex items-center gap-1">
      <!-- Fork icon -->
      <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.5h-1.5A2.25 2.25 0 0 1 3.5 6.25v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z"/>
      </svg>
      {fmt(forks)}
    </span>

    <span class="text-pine/20 dark:text-fog/20">·</span>

    <span>{license}</span>
  </div>
</a>
