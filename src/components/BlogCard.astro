---
interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
  slug: string;
  compact?: boolean;
  readingTime?: number;
}

const { title, date, description, tags, slug, compact = false, readingTime } = Astro.props;

const dateLabel = date.toLocaleDateString('en-GB', {
  day: 'numeric', month: 'short', year: 'numeric',
});
---

<article
  class:list={[
    'group flex flex-col bg-white dark:bg-white/8 border border-pine/10 dark:border-white/10 rounded-xl transition-all duration-200',
    'hover:border-jungle/50 dark:hover:border-mint/30 hover:shadow-lg hover:-translate-y-0.5',
    compact ? 'p-4' : 'p-6',
  ]}
>
  <div class="flex items-center gap-2 mb-2">
    <time
      datetime={date.toISOString()}
      class="text-xs text-pine/65 dark:text-fog/55"
    >
      {dateLabel}
    </time>
    {readingTime && (
      <span class="text-xs text-pine/50 dark:text-fog/50 flex items-center gap-1">
        <span>·</span>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2" />
        </svg>
        {readingTime} min read
      </span>
    )}
  </div>

  <h3
    class:list={[
      'font-display font-semibold text-pine dark:text-fog group-hover:text-jungle dark:group-hover:text-mint transition-colors leading-snug mb-3',
      compact ? 'text-base' : 'text-xl',
    ]}
  >
    <a href={`/blog/${slug}`}>{title}</a>
  </h3>

  {!compact && (
    <p class="text-sm text-pine/65 dark:text-fog/60 leading-relaxed mb-4 flex-1">
      {description}
    </p>
  )}

  <div class="flex flex-wrap gap-1.5 mb-4">
    {tags.slice(0, compact ? 3 : 4).map(tag => (
      <a
        href={`/topics/${encodeURIComponent(tag)}`}
        class="text-xs bg-mint/15 dark:bg-pine/60 text-pine/70 dark:text-mint/80 px-2 py-0.5 rounded-full border border-mint/20 dark:border-mint/15 hover:bg-mint/30 dark:hover:bg-pine/80 transition-colors"
      >
        {tag}
      </a>
    ))}
  </div>

  <a
    href={`/blog/${slug}`}
    class="mt-auto text-sm font-medium text-jungle dark:text-mint hover:underline underline-offset-2"
  >
    Read more →
  </a>
</article>
